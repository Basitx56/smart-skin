<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.UserManagementController"
            stylesheets="@../styles/darktheme.css"
            prefWidth="1200" prefHeight="740">
    <left>
        <VBox styleClass="sidebar" spacing="4">
            <padding><Insets top="24" right="12" bottom="24" left="12"/></padding>
            <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 4 0 4;">
                <Label text="✦" styleClass="sidebar-logo-label"/>
                <Label text="SmartSkin" styleClass="sidebar-app-name"/>
            </HBox>
            <Region prefHeight="12"/>
            <Label text="Admin Panel" style="-fx-text-fill: #D4537E; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 4 0 4;"/>
            <Region prefHeight="16"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Label text="MENU" style="-fx-text-fill: #999999; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 4 0 4;"/>
            <Region prefHeight="4"/>
            <Button text="👥  User Management"    styleClass="sidebar-nav-button-active" maxWidth="Infinity"/>
            <Button text="💄  Product Management" onAction="#goProductManagement" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Pane VBox.vgrow="ALWAYS"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Button text="Sign out" onAction="#onLogout" styleClass="button-danger" maxWidth="Infinity"/>
        </VBox>
    </left>
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT">
            <Label text="User Management" styleClass="topbar-title"/>
        </HBox>
    </top>
    <center>
        <VBox styleClass="content-area" spacing="18">
            <Label text="User Management" styleClass="page-title"/>

            <!-- Toolbar -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search by name or email..." HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="filterBox" promptText="Filter by role" prefWidth="160"/>
                <Button text="Create User" onAction="#onCreateUser" styleClass="button-primary"/>
                <Button text="Activate / Deactivate" onAction="#onDeactivateActivate" styleClass="button-warning"/>
                <Button text="Change Role" onAction="#onChangeRole" styleClass="button-secondary"/>
            </HBox>

            <!-- Users table -->
            <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colName"       text="Name"       prefWidth="160"/>
                    <TableColumn fx:id="colEmail"      text="Email"      prefWidth="220"/>
                    <TableColumn fx:id="colRole"       text="Role"       prefWidth="110"/>
                    <TableColumn fx:id="colStatus"     text="Status"     prefWidth="100"/>
                    <TableColumn fx:id="colRegistered" text="Registered" prefWidth="160"/>
                </columns>
            </TableView>

            <!-- Audit log -->
            <Label text="AUDIT LOG" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
            <TableView fx:id="auditTable" prefHeight="180">
                <columns>
                    <TableColumn fx:id="auditActorCol"  text="Actor"     prefWidth="180"/>
                    <TableColumn fx:id="auditActionCol" text="Action"    prefWidth="400"/>
                    <TableColumn fx:id="auditTimeCol"   text="Timestamp" prefWidth="180"/>
                </columns>
            </TableView>

            <Label fx:id="statusLabel" text="" styleClass="label-success" wrapText="true"/>
        </VBox>
    </center>
</BorderPane>