<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.DetectConflictsController"
            stylesheets="@../styles/darktheme.css"
            prefWidth="1200" prefHeight="740">
    <left>
        <VBox styleClass="sidebar" spacing="4">
            <padding><Insets top="24" right="12" bottom="24" left="12"/></padding>
            <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 4 0 4;">
                <Label text="✦" styleClass="sidebar-logo-label"/>
                <Label text="SmartSkin" styleClass="sidebar-app-name"/>
            </HBox>
            <Region prefHeight="20"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Label text="MENU" style="-fx-text-fill: #999999; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 4 0 4;"/>
            <Region prefHeight="4"/>
            <Button text="🏠  Dashboard"       onAction="#goDashboard"    styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="👤  Skin Profile"    onAction="#goSkinProfile"  styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="📸  Upload Photo"    onAction="#goUploadPhoto"  styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="🔍  Search Products" onAction="#goSearch"       styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="📅  Book Appointment" onAction="#goAppointment" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="✨  My Routine"      onAction="#goRoutine"      styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="⚠  Conflict Checker" styleClass="sidebar-nav-button-active" maxWidth="Infinity"/>
            <Button text="📊  Track Progress"  onAction="#goProgress"     styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="❤  Favorites"       onAction="#goFavorites"    styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="🔔  Notifications"   onAction="#goNotifications" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Pane VBox.vgrow="ALWAYS"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Button text="Sign out" onAction="#onLogout" styleClass="button-danger" maxWidth="Infinity"/>
        </VBox>
    </left>
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT">
            <Label text="Ingredient Conflict Checker" styleClass="topbar-title"/>
        </HBox>
    </top>
    <center>
        <HBox styleClass="content-area" spacing="20">
            <!-- Search + Result panel -->
            <VBox spacing="16" HBox.hgrow="ALWAYS">
                <Label text="Ingredient Conflict Checker" styleClass="page-title"/>
                <HBox spacing="10">
                    <TextField fx:id="searchField" promptText="Search product by name or ingredient..." HBox.hgrow="ALWAYS"/>
                    <ProgressIndicator fx:id="loadingIndicator" visible="false" prefWidth="22" prefHeight="22"/>
                </HBox>
                <ListView fx:id="suggestionsList" prefHeight="110" visible="false"
                          style="-fx-background-color: #1E1E1E; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 10; -fx-background-radius: 10;"/>

                <!-- Selected product info -->
                <VBox styleClass="card" spacing="10">
                    <Label text="SELECTED PRODUCT" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label fx:id="selectedProductLabel" text="No product selected" styleClass="label-muted"/>
                    <Label fx:id="ingredientsLabel" text="" wrapText="true"
                           style="-fx-text-fill: #777777; -fx-font-size: 13px;"/>
                </VBox>

                <!-- Result banners -->
                <VBox fx:id="safeBanner" visible="false" styleClass="banner-safe" spacing="6">
                    <Label text="✓  Safe to Use" style="-fx-text-fill: #4CAF50; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <Label text="No conflicts detected with your current routine."
                           style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 13px;"/>
                </VBox>
                <VBox fx:id="resultBanner" visible="false" styleClass="banner-warning" spacing="6">
                    <Label fx:id="resultText" text="" style="-fx-text-fill: #FF9800; -fx-font-size: 14px; -fx-font-weight: bold;" wrapText="true"/>
                    <CheckBox fx:id="acknowledgeBox" text="I understand the risk and want to proceed"/>
                </VBox>

                <HBox spacing="10">
                    <Button text="See Safer Alternatives" onAction="#onShowAlternatives" styleClass="button-secondary"/>
                </HBox>
                <VBox fx:id="alternativesBox" visible="false" styleClass="card" spacing="8"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>