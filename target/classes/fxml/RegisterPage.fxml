<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane xmlns:fx="http://javafx.com/fxml" 
           fx:controller="ui.RegisterController"
           prefWidth="1080" prefHeight="720"
           style="-fx-background-color: linear-gradient(to bottom right, #D4537E, #9c3a59, #D4537E); -fx-background-radius: 0;">

    <!-- This Pane adds a subtle 'mesh' or 'pattern' overlay like the smoke in image_8397fa.png -->
    <Pane opacity="0.1" mouseTransparent="true" 
          style="-fx-background-image: url('https://www.transparenttextures.com/patterns/carbon-fibre.png'); -fx-background-repeat: repeat;"/>

    <HBox maxWidth="950" maxHeight="600" 
          style="-fx-background-color: #cdcdcd; -fx-background-radius: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 30, 0, 0, 15);">
        
        <!-- LEFT PANEL (The "Athlete" side from the reference, now your Brand side) -->
        <VBox prefWidth="450" alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #111111; -fx-background-radius: 25 0 0 25; -fx-padding: 40;">
            
            <!-- Icon/Logo -->
            <Label text="✦" style="-fx-text-fill: #D4537E; -fx-font-size: 60; -fx-font-weight: bold;"/>
            <Label text="SmartSkin" style="-fx-text-fill: #FFFFFF; -fx-font-size: 36; -fx-font-weight: bold;"/>
            <Label text="Your personal skin health companion" 
                   style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 14; -fx-text-alignment: center;" wrapText="true"/>
            
            <Region prefHeight="40"/>
            
            <!-- Features list with pink accents -->
            <VBox spacing="12" maxWidth="250">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="✔" style="-fx-text-fill: #D4537E; -fx-font-weight: bold;"/>
                    <Label text="Custom routines" style="-fx-text-fill: white; -fx-font-size: 13;"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="✔" style="-fx-text-fill: #D4537E; -fx-font-weight: bold;"/>
                    <Label text="Expert consultation" style="-fx-text-fill: white; -fx-font-size: 13;"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- RIGHT PANEL (The Form side) -->
        <VBox prefWidth="500" alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 0 25 25 0;">
            <padding><Insets top="50" right="70" bottom="50" left="70"/></padding>
            
            <Label text="Create account" style="-fx-text-fill: #111111; -fx-font-size: 28; -fx-font-weight: bold;"/>
            <Label text="Set up your personalized skincare profile" style="-fx-text-fill: #777777; -fx-font-size: 14;"/>
            
            <Region prefHeight="40"/>

            <!-- Form Fields -->
            <Label text="FULL NAME" style="-fx-text-fill: #999999; -fx-font-size: 11; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
            <Region prefHeight="8"/>
            <TextField fx:id="nameField" promptText="Your full name" 
                       style="-fx-background-color: #f8f8f8; -fx-border-color: #eeeeee; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;"/>
            
            <Region prefHeight="20"/>

            <Label text="EMAIL ADDRESS" style="-fx-text-fill: #999999; -fx-font-size: 11; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
            <Region prefHeight="8"/>
            <TextField fx:id="emailField" promptText="your@email.com" 
                       style="-fx-background-color: #f8f8f8; -fx-border-color: #eeeeee; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;"/>
            
            <Region prefHeight="20"/>

            <Label text="PASSWORD" style="-fx-text-fill: #999999; -fx-font-size: 11; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
            <Region prefHeight="8"/>
            <PasswordField fx:id="passwordField" promptText="Min 8 chars, 1 upper, 1 digit, 1 symbol" 
                           style="-fx-background-color: #f8f8f8; -fx-border-color: #eeeeee; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;"/>
            
            <Region prefHeight="6"/>
            <Region fx:id="strengthBar" prefHeight="5"
                    style="-fx-background-color: #eeeeee; -fx-background-radius: 3;"/>
            <Label fx:id="passwordError" text="" style="-fx-text-fill: #F44336; -fx-font-size: 12;" wrapText="true"/>
            <Region prefHeight="16"/>

            <Label text="CONFIRM PASSWORD" style="-fx-text-fill: #999999; -fx-font-size: 11; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
            <Region prefHeight="8"/>
            <PasswordField fx:id="confirmPasswordField" promptText="Re-enter password" 
                           style="-fx-background-color: #f8f8f8; -fx-border-color: #eeeeee; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;"/>
            <Region prefHeight="20"/>

            <HBox spacing="12">
                <VBox HBox.hgrow="ALWAYS" spacing="7">
                    <Label text="AGE" style="-fx-text-fill: #999999; -fx-font-size: 11; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
                    <TextField fx:id="ageField" promptText="Age" 
                               style="-fx-background-color: #f8f8f8; -fx-border-color: #eeeeee; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="7">
                    <Label text="GENDER" style="-fx-text-fill: #999999; -fx-font-size: 11; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
                    <ComboBox fx:id="genderBox" promptText="Select" maxWidth="Infinity"
                              style="-fx-background-color: #f8f8f8; -fx-border-color: #eeeeee; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;"/>
                </VBox>
            </HBox>
            <Region prefHeight="20"/>

            <Label fx:id="generalError" text="" style="-fx-text-fill: #F44336; -fx-font-size: 14;" wrapText="true"/>
            <Region prefHeight="20"/>

            <!-- Action Buttons -->
            <Button fx:id="registerButton" text="Create account" onAction="#onRegister" maxWidth="Infinity"
                style="-fx-background-color: #D4537E; -fx-text-fill: white; -fx-font-size: 15; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12; -fx-cursor: hand;"/>
            
            <Region prefHeight="15"/>
            
            <HBox alignment="CENTER" spacing="10">
                <Label text="" style="-fx-text-fill: #999999; -fx-font-size: 13;"/>
                <ProgressIndicator fx:id="loadingIndicator" visible="false" prefWidth="20" prefHeight="20"/>
            </HBox>

            <Region prefHeight="40"/>
            
            <HBox alignment="CENTER" spacing="5">
                <Label text="Already have an account?" style="-fx-text-fill: #999999; -fx-font-size: 13;"/>
                <Hyperlink text="Sign in" onAction="#onBackToLogin" 
                           style="-fx-text-fill: #D4537E; -fx-font-weight: bold; -fx-underline: false;"/>
            </HBox>
        </VBox>
    </HBox>
</StackPane>