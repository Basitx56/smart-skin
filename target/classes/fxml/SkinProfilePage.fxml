<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.SkinProfileController"
            stylesheets="@../styles/darktheme.css"
            prefWidth="1200" prefHeight="740">
    <left>
        <VBox styleClass="sidebar" spacing="4">
            <padding><Insets top="24" right="12" bottom="24" left="12"/></padding>
            <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 4 0 4;">
                <Label text="✦" styleClass="sidebar-logo-label"/>
                <Label text="SmartSkin" styleClass="sidebar-app-name"/>
            </HBox>
            <Region prefHeight="20"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Label text="MENU" style="-fx-text-fill: #999999; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 4 0 4;"/>
            <Region prefHeight="4"/>
            <Button text="🏠  Dashboard"       onAction="#goDashboard"    styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="👤  Skin Profile"    styleClass="sidebar-nav-button-active" maxWidth="Infinity"/>
            <Button text="📸  Upload Photo"    onAction="#goUploadPhoto"  styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="🔍  Search Products" onAction="#goSearch"       styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="📅  Book Appointment" onAction="#goAppointment" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="✨  My Routine"      onAction="#goRoutine"      styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="⚠  Conflict Checker" onAction="#goConflict"    styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="📊  Track Progress"  onAction="#goProgress"     styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="❤  Favorites"       onAction="#goFavorites"    styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="🔔  Notifications"   onAction="#goNotifications" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Pane VBox.vgrow="ALWAYS"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Button text="Sign out" onAction="#onLogout" styleClass="button-danger" maxWidth="Infinity"/>
        </VBox>
    </left>
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT">
            <Label text="Skin Profile" styleClass="topbar-title"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane" style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox styleClass="content-area" spacing="20">
                    <Label text="My Skin Profile" styleClass="page-title"/>

                    <!-- Completeness -->
                    <VBox styleClass="card" spacing="10">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Profile Completeness" style="-fx-text-fill: #777777; -fx-font-size: 13px;"/>
                            <Pane HBox.hgrow="ALWAYS"/>
                            <Label fx:id="completenessLabel" text="0% complete" styleClass="label-accent"/>
                        </HBox>
                        <ProgressBar fx:id="completenessBar" progress="0" maxWidth="Infinity"/>
                    </VBox>

                    <!-- Skin Type -->
                    <VBox styleClass="card" spacing="14">
                        <Label text="SKIN TYPE" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <HBox spacing="14">
                            <fx:define><ToggleGroup fx:id="skinTypeGroup"/></fx:define>
                            <RadioButton fx:id="oilyBtn"       text="Oily"        toggleGroup="$skinTypeGroup"/>
                            <RadioButton fx:id="dryBtn"        text="Dry"         toggleGroup="$skinTypeGroup"/>
                            <RadioButton fx:id="combinationBtn" text="Combination" toggleGroup="$skinTypeGroup"/>
                            <RadioButton fx:id="sensitiveBtn"  text="Sensitive"   toggleGroup="$skinTypeGroup"/>
                            <RadioButton fx:id="normalBtn"     text="Normal"      toggleGroup="$skinTypeGroup"/>
                        </HBox>
                    </VBox>

                    <!-- Skin Concerns -->
                    <VBox styleClass="card" spacing="14">
                        <Label text="SKIN CONCERNS" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <FlowPane hgap="16" vgap="12">
                            <CheckBox fx:id="concernAcne"        text="Acne"/>
                            <CheckBox fx:id="concernDryness"     text="Dryness"/>
                            <CheckBox fx:id="concernPigmentation" text="Pigmentation"/>
                            <CheckBox fx:id="concernAging"       text="Aging"/>
                            <CheckBox fx:id="concernOiliness"    text="Oiliness"/>
                            <CheckBox fx:id="concernSensitivity" text="Sensitivity"/>
                        </FlowPane>
                    </VBox>

                    <!-- Allergies -->
                    <VBox styleClass="card" spacing="14">
                        <Label text="KNOWN ALLERGIES" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <HBox spacing="10">
                            <TextField fx:id="allergyField" promptText="Type allergy and click Add" HBox.hgrow="ALWAYS"/>
                            <Button text="Add" onAction="#onAddAllergy" styleClass="button-primary"/>
                        </HBox>
                        <ListView fx:id="allergiesList" prefHeight="90" styleClass="list-view"/>
                    </VBox>

                    <!-- Current Products + Lifestyle -->
                    <HBox spacing="14">
                        <VBox styleClass="card" spacing="14" HBox.hgrow="ALWAYS">
                            <Label text="CURRENT PRODUCTS IN USE" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                            <TextArea fx:id="currentProductsArea" promptText="List your current skincare products..." prefHeight="120"/>
                        </VBox>
                        <VBox styleClass="card" spacing="14" HBox.hgrow="ALWAYS">
                            <Label text="LIFESTYLE" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                            <VBox spacing="10">
                                <ComboBox fx:id="dietBox" promptText="Diet quality" maxWidth="Infinity"/>
                                <ComboBox fx:id="stressBox" promptText="Stress level" maxWidth="Infinity"/>
                                <ComboBox fx:id="sunBox" promptText="Sun exposure" maxWidth="Infinity"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="Sleep" style="-fx-text-fill: #777777; -fx-font-size: 13px;"/>
                                    <Slider fx:id="sleepSlider" min="4" max="10" value="7" HBox.hgrow="ALWAYS" blockIncrement="1"/>
                                    <Label fx:id="sleepValueLabel" text="7h" styleClass="label-accent" minWidth="28"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </HBox>

                    <!-- Actions -->
                    <HBox spacing="12">
                        <Button text="Save Profile" onAction="#onSaveProfile" styleClass="button-primary"/>
                        <ProgressIndicator fx:id="loadingIndicator" visible="false" prefWidth="22" prefHeight="22"/>
                    </HBox>
                    <Label fx:id="statusLabel" text="" styleClass="label-success" wrapText="true"/>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>