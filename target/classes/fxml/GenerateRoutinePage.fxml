<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.GenerateRoutineController"
            stylesheets="@../styles/darktheme.css"
            prefWidth="1200" prefHeight="740">
    <left>
        <VBox styleClass="sidebar" spacing="4">
            <padding><Insets top="24" right="12" bottom="24" left="12"/></padding>
            <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 4 0 4;">
                <Label text="✦" styleClass="sidebar-logo-label"/>
                <Label text="SmartSkin" styleClass="sidebar-app-name"/>
            </HBox>
            <Region prefHeight="20"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Label text="MENU" style="-fx-text-fill: #999999; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 4 0 4;"/>
            <Region prefHeight="4"/>
            <Button text="🏠  Dashboard"       onAction="#goDashboard"    styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="👤  Skin Profile"    onAction="#goSkinProfile"  styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="📸  Upload Photo"    onAction="#goUploadPhoto"  styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="🔍  Search Products" onAction="#goSearch"       styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="📅  Book Appointment" onAction="#goAppointment" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="✨  My Routine"      styleClass="sidebar-nav-button-active" maxWidth="Infinity"/>
            <Button text="⚠  Conflict Checker" onAction="#goConflict"    styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="📊  Track Progress"  onAction="#goProgress"     styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="❤  Favorites"       onAction="#goFavorites"    styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="🔔  Notifications"   onAction="#goNotifications" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Pane VBox.vgrow="ALWAYS"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Button text="Sign out" onAction="#onLogout" styleClass="button-danger" maxWidth="Infinity"/>
        </VBox>
    </left>
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT">
            <Label text="My Skincare Routine" styleClass="topbar-title"/>
        </HBox>
    </top>
    <center>
        <VBox styleClass="content-area" spacing="18">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="My Skincare Routine" styleClass="page-title"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Generate" onAction="#onGenerate" styleClass="button-primary"/>
                <Button text="Regenerate" onAction="#onRegenerate" styleClass="button-secondary"/>
                <Button text="Save" onAction="#onSaveRoutine" styleClass="button-secondary"/>
                <Button text="Export PDF" onAction="#onExportPdf" styleClass="button-secondary"/>
                <ProgressIndicator fx:id="loadingIndicator" visible="false" prefWidth="22" prefHeight="22"/>
            </HBox>

            <!-- Incomplete profile warning -->
            <VBox fx:id="incompleteWarning" visible="false" styleClass="banner-warning" spacing="8">
                <Label fx:id="incompleteLabel" text="Complete your skin profile first to generate a routine."
                       style="-fx-text-fill: #FF9800; -fx-font-size: 13px;" wrapText="true"/>
                <ProgressBar fx:id="profileProgress" progress="0" maxWidth="200"/>
                <Hyperlink fx:id="profileLink" text="Go to Skin Profile →" onAction="#onGoProfile"/>
            </VBox>

            <Label fx:id="statusLabel" text="" styleClass="label-success" wrapText="true"/>

            <!-- Routine cards side by side -->
            <HBox spacing="16" VBox.vgrow="ALWAYS">
                <ScrollPane fitToWidth="true" styleClass="scroll-pane" HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
                    <content>
                        <VBox fx:id="morningCard" styleClass="card" spacing="14" style="-fx-background-color: transparent;">
                            <Label text="☀  Morning Routine"
                                   style="-fx-text-fill: #FFFFFF; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                            <Label text="Generate your routine to see morning steps"
                                   style="-fx-text-fill: rgba(255,255,255,0.25); -fx-font-size: 13px;"/>
                        </VBox>
                    </content>
                </ScrollPane>
                <ScrollPane fitToWidth="true" styleClass="scroll-pane" HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
                    <content>
                        <VBox fx:id="eveningCard" styleClass="card" spacing="14" style="-fx-background-color: transparent;">
                            <Label text="☾  Evening Routine"
                                   style="-fx-text-fill: #FFFFFF; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                            <Label text="Generate your routine to see evening steps"
                                   style="-fx-text-fill: rgba(255,255,255,0.25); -fx-font-size: 13px;"/>
                        </VBox>
                    </content>
                </ScrollPane>
            </HBox>
        </VBox>
    </center>
</BorderPane>