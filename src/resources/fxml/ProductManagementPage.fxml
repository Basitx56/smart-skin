<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.ProductManagementController"
            stylesheets="@../styles/darktheme.css"
            prefWidth="1200" prefHeight="740">
    <left>
        <VBox styleClass="sidebar" spacing="4">
            <padding><Insets top="24" right="12" bottom="24" left="12"/></padding>
            <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 4 0 4;">
                <Label text="✦" styleClass="sidebar-logo-label"/>
                <Label text="SmartSkin" styleClass="sidebar-app-name"/>
            </HBox>
            <Region prefHeight="12"/>
            <Label text="Admin Panel" style="-fx-text-fill: #D4537E; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 4 0 4;"/>
            <Region prefHeight="16"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Label text="MENU" style="-fx-text-fill: #999999; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 4 0 4;"/>
            <Region prefHeight="4"/>
            <Button text="👥  User Management"    onAction="#goUserManagement" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="💄  Product Management" styleClass="sidebar-nav-button-active" maxWidth="Infinity"/>
            <Pane VBox.vgrow="ALWAYS"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Button text="Sign out" onAction="#onLogout" styleClass="button-danger" maxWidth="Infinity"/>
        </VBox>
    </left>
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT">
            <Label text="Product Management" styleClass="topbar-title"/>
        </HBox>
    </top>
    <center>
        <VBox styleClass="content-area" spacing="18">
            <Label text="Product Database" styleClass="page-title"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search products..." HBox.hgrow="ALWAYS"/>
                <Button text="Add New Product" onAction="#onAddProduct" styleClass="button-primary"/>
                <Button text="Edit Selected"   onAction="#onEditProduct" styleClass="button-secondary"/>
                <Button text="Delete Selected" onAction="#onDeleteProduct" styleClass="button-danger"/>
            </HBox>

            <TableView fx:id="productsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colName"     text="Product Name" prefWidth="280"/>
                    <TableColumn fx:id="colBrand"    text="Brand"        prefWidth="180"/>
                    <TableColumn fx:id="colCategory" text="Category"     prefWidth="160"/>
                    <TableColumn fx:id="colPrice"    text="Price"        prefWidth="100"/>
                </columns>
            </TableView>

            <Label fx:id="statusLabel" text="" styleClass="label-success" wrapText="true"/>
        </VBox>
    </center>
</BorderPane>