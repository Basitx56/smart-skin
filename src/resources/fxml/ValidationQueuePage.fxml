<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.ValidationQueueController"
            stylesheets="@../styles/darktheme.css"
            prefWidth="1200" prefHeight="740">
    <left>
        <VBox styleClass="sidebar" spacing="4">
            <padding><Insets top="24" right="12" bottom="24" left="12"/></padding>
            <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 4 0 4;">
                <Label text="✦" styleClass="sidebar-logo-label"/>
                <Label text="SmartSkin" styleClass="sidebar-app-name"/>
            </HBox>
            <Region prefHeight="12"/>
            <Label text="Expert Portal" style="-fx-text-fill: #D4537E; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 4 0 4;"/>
            <Region prefHeight="16"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Label text="MENU" style="-fx-text-fill: #999999; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 4 0 4;"/>
            <Region prefHeight="4"/>
            <Button text="✅  Validation Queue" styleClass="sidebar-nav-button-active" maxWidth="Infinity"/>
            <Pane VBox.vgrow="ALWAYS"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Button text="Sign out" onAction="#onLogout" styleClass="button-danger" maxWidth="Infinity"/>
        </VBox>
    </left>
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="Validation Queue" styleClass="topbar-title"/>
            <Label text="Pending:" style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 13px;"/>
            <Label fx:id="pendingCountLabel" text="0" styleClass="badge"/>
        </HBox>
    </top>
    <center>
        <HBox styleClass="content-area" spacing="20">
            <!-- Queue table -->
            <VBox styleClass="card" spacing="12" HBox.hgrow="ALWAYS">
                <Label text="PENDING RECOMMENDATIONS" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <TableView fx:id="queueTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colDate"     text="Submitted"  prefWidth="160"/>
                        <TableColumn fx:id="colSkinType" text="Skin Type"  prefWidth="130"/>
                        <TableColumn fx:id="colStatus"   text="Status"     prefWidth="110"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Review panel -->
            <VBox styleClass="card" spacing="14" prefWidth="340" minWidth="300">
                <Label text="REVIEW PANEL" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <Label fx:id="profileLabel" text="Select an item from the queue to review."
                       styleClass="label-muted" wrapText="true"/>

                <VBox spacing="6">
                    <Label text="MORNING STEPS" style="-fx-text-fill: #999999; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <VBox fx:id="morningBox" spacing="4"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="EVENING STEPS" style="-fx-text-fill: #999999; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <VBox fx:id="eveningBox" spacing="4"/>
                </VBox>

                <TextField fx:id="rejectionReasonField" promptText="Reason (required for Reject / Flag)"/>

                <VBox spacing="8">
                    <Button text="✅  Approve"       onAction="#onApprove"      styleClass="button-success"  maxWidth="Infinity"/>
                    <Button text="✏  Modify"         onAction="#onModify"       styleClass="button-warning"  maxWidth="Infinity"/>
                    <Button text="✗  Reject"         onAction="#onReject"       styleClass="button-danger"   maxWidth="Infinity"/>
                    <Button text="🚩  Flag Safety"   onAction="#onFlagSafety"
                            style="-fx-background-color: rgba(139,0,0,0.3); -fx-text-fill: #FF4444; -fx-border-color: rgba(139,0,0,0.5); -fx-border-radius: 10; -fx-background-radius: 10; -fx-border-width: 1; -fx-padding: 11 22 11 22; -fx-cursor: hand; -fx-pref-height: 44px;"
                            maxWidth="Infinity"/>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>