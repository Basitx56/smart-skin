<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.DeleteAccountController"
            stylesheets="@../styles/darktheme.css"
            prefWidth="1200" prefHeight="740">
    <left>
        <VBox styleClass="sidebar" spacing="4">
            <padding><Insets top="24" right="12" bottom="24" left="12"/></padding>
            <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 4 0 4;">
                <Label text="✦" styleClass="sidebar-logo-label"/>
                <Label text="SmartSkin" styleClass="sidebar-app-name"/>
            </HBox>
            <Region prefHeight="20"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Label text="MENU" style="-fx-text-fill: #999999; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 4 0 4;"/>
            <Region prefHeight="4"/>
            <Button text="🏠  Dashboard"       onAction="#goDashboard"    styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="👤  Skin Profile"    onAction="#goSkinProfile"  styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="📸  Upload Photo"    onAction="#goUploadPhoto"  styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="🔍  Search Products" onAction="#goSearch"       styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="📅  Book Appointment" onAction="#goAppointment" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="✨  My Routine"      onAction="#goRoutine"      styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="⚠  Conflict Checker" onAction="#goConflict"    styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="📊  Track Progress"  onAction="#goProgress"     styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="❤  Favorites"       onAction="#goFavorites"    styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="🔔  Notifications"   onAction="#goNotifications" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Pane VBox.vgrow="ALWAYS"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Button text="Sign out" onAction="#onLogout" styleClass="button-danger" maxWidth="Infinity"/>
        </VBox>
    </left>
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT">
            <Label text="Account Settings" styleClass="topbar-title"/>
        </HBox>
    </top>
    <center>
        <VBox styleClass="content-area" alignment="TOP_CENTER">
            <VBox maxWidth="520" spacing="20">
                <Label text="Delete Account" style="-fx-text-fill: #F44336; -fx-font-size: 22px; -fx-font-weight: bold;"/>

                <VBox styleClass="card-danger" spacing="12">
                    <Label text="⚠  This action is PERMANENT and cannot be undone."
                           style="-fx-text-fill: #F44336; -fx-font-size: 14px; -fx-font-weight: bold;" wrapText="true"/>
                    <Label text="The following data will be permanently deleted:"
                           style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 13px;"/>
                    <VBox spacing="6" style="-fx-padding: 0 0 0 12;">
                        <Label text="✗  Your skin profile and analysis" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 13px;"/>
                        <Label text="✗  All skincare routines" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 13px;"/>
                        <Label text="✗  Progress history and photos" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 13px;"/>
                        <Label text="✗  Saved favorite products" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 13px;"/>
                        <Label text="✗  Appointment history" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 13px;"/>
                    </VBox>
                </VBox>

                <VBox styleClass="card" spacing="12">
                    <Label text="CONFIRM YOUR PASSWORD" style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <PasswordField fx:id="passwordField" promptText="Enter your current password to confirm"/>
                    <HBox spacing="12">
                        <Button text="Delete My Account" onAction="#onDelete" styleClass="button-danger"/>
                        <Button text="Cancel" onAction="#onCancel" styleClass="button-secondary"/>
                    </HBox>
                    <Label fx:id="statusLabel" text="" wrapText="true" styleClass="label-error"/>
                </VBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>