<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.BookAppointmentController"
            stylesheets="@../styles/darktheme.css"
            prefWidth="1200" prefHeight="740">
    <left>
        <VBox styleClass="sidebar" spacing="4">
            <padding><Insets top="24" right="12" bottom="24" left="12"/></padding>
            <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 4 0 4;">
                <Label text="✦" styleClass="sidebar-logo-label"/>
                <Label text="SmartSkin" styleClass="sidebar-app-name"/>
            </HBox>
            <Region prefHeight="20"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Label text="MENU" style="-fx-text-fill: #999999; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 4 0 4;"/>
            <Region prefHeight="4"/>
            <Button text="🏠  Dashboard"       onAction="#goDashboard"    styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="👤  Skin Profile"    onAction="#goSkinProfile"  styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="📸  Upload Photo"    onAction="#goUploadPhoto"  styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="🔍  Search Products" onAction="#goSearch"       styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="📅  Book Appointment" styleClass="sidebar-nav-button-active" maxWidth="Infinity"/>
            <Button text="✨  My Routine"      onAction="#goRoutine"      styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="⚠  Conflict Checker" onAction="#goConflict"    styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="📊  Track Progress"  onAction="#goProgress"     styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="❤  Favorites"       onAction="#goFavorites"    styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="🔔  Notifications"   onAction="#goNotifications" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Pane VBox.vgrow="ALWAYS"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Button text="Sign out" onAction="#onLogout" styleClass="button-danger" maxWidth="Infinity"/>
        </VBox>
    </left>
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT">
            <Label text="Book Appointment" styleClass="topbar-title"/>
        </HBox>
    </top>
    <center>
        <HBox styleClass="content-area" spacing="20">
            <!-- Expert list -->
            <VBox styleClass="card" spacing="14" prefWidth="340" minWidth="300">
                <Label text="AVAILABLE EXPERTS" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <ListView fx:id="expertsList" VBox.vgrow="ALWAYS" styleClass="list-view"/>
            </VBox>

            <!-- Booking panel -->
            <VBox styleClass="card" spacing="16" HBox.hgrow="ALWAYS">
                <Label text="BOOKING DETAILS" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <Label fx:id="expertDetailsLabel" text="Select an expert from the list to continue"
                       styleClass="label-muted" wrapText="true"/>

                <VBox spacing="8">
                    <Label text="SELECT DATE" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <DatePicker fx:id="datePicker" maxWidth="Infinity"/>
                </VBox>
                <HBox spacing="12">
                    <VBox HBox.hgrow="ALWAYS" spacing="8">
                        <Label text="TIME SLOT" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="slotBox" promptText="Select slot" maxWidth="Infinity"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="8">
                        <Label text="TYPE" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="typeBox" promptText="Consultation type" maxWidth="Infinity"/>
                    </VBox>
                </HBox>

                <VBox styleClass="card-accent" spacing="6">
                    <Label text="BOOKING SUMMARY" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label fx:id="feeLabel" text="Fee: —" style="-fx-text-fill: #777777; -fx-font-size: 14px;"/>
                    <Label fx:id="holdTimerLabel" text="" visible="false" styleClass="label-accent"
                           style="-fx-font-size: 13px;"/>
                </VBox>

                <HBox spacing="12">
                    <Button text="Confirm Booking" onAction="#onConfirmBooking" styleClass="button-primary"/>
                    <ProgressIndicator fx:id="loadingIndicator" visible="false" prefWidth="22" prefHeight="22"/>
                </HBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>