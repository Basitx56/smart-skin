<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.NotificationSettingsController"
            stylesheets="@../styles/darktheme.css"
            prefWidth="1200" prefHeight="740">
    <left>
        <VBox styleClass="sidebar" spacing="4">
            <padding><Insets top="24" right="12" bottom="24" left="12"/></padding>
            <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 4 0 4;">
                <Label text="✦" styleClass="sidebar-logo-label"/>
                <Label text="SmartSkin" styleClass="sidebar-app-name"/>
            </HBox>
            <Region prefHeight="20"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Label text="MENU" style="-fx-text-fill: #999999; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 4 0 4;"/>
            <Region prefHeight="4"/>
            <Button text="🏠  Dashboard"       onAction="#goDashboard"    styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="👤  Skin Profile"    onAction="#goSkinProfile"  styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="📸  Upload Photo"    onAction="#goUploadPhoto"  styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="🔍  Search Products" onAction="#goSearch"       styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="📅  Book Appointment" onAction="#goAppointment" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="✨  My Routine"      onAction="#goRoutine"      styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="⚠  Conflict Checker" onAction="#goConflict"    styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="📊  Track Progress"  onAction="#goProgress"     styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="❤  Favorites"       onAction="#goFavorites"    styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button text="🔔  Notifications"   styleClass="sidebar-nav-button-active" maxWidth="Infinity"/>
            <Pane VBox.vgrow="ALWAYS"/>
            <Region styleClass="sidebar-divider"/>
            <Region prefHeight="10"/>
            <Button text="Sign out" onAction="#onLogout" styleClass="button-danger" maxWidth="Infinity"/>
        </VBox>
    </left>
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT">
            <Label text="Notifications" styleClass="topbar-title"/>
        </HBox>
    </top>
    <center>
        <VBox styleClass="content-area" spacing="20">
            <Label text="Notification Settings" styleClass="page-title"/>

            <!-- Settings card -->
            <VBox styleClass="card" spacing="16">
                <Label text="REMINDER SETTINGS" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <CheckBox fx:id="enableCheck" text="Enable routine reminders"/>
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <VBox spacing="8">
                        <Label text="MORNING REMINDER" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <ComboBox fx:id="morningHourBox" prefWidth="80"/>
                            <Label text=":" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 18px;"/>
                            <ComboBox fx:id="morningMinuteBox" prefWidth="80"/>
                        </HBox>
                    </VBox>
                    <VBox spacing="8">
                        <Label text="EVENING REMINDER" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <ComboBox fx:id="eveningHourBox" prefWidth="80"/>
                            <Label text=":" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 18px;"/>
                            <ComboBox fx:id="eveningMinuteBox" prefWidth="80"/>
                        </HBox>
                    </VBox>
                    <VBox alignment="BOTTOM_LEFT">
                        <Button text="Save Settings" onAction="#onSaveSettings" styleClass="button-primary"/>
                    </VBox>
                    <ProgressIndicator fx:id="loadingIndicator" visible="false" prefWidth="22" prefHeight="22"/>
                </HBox>
                <Label fx:id="previewLabel" text="" styleClass="label-accent"/>
            </VBox>

            <!-- History -->
            <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">
                <Label text="NOTIFICATION HISTORY" style="-fx-text-fill: #999999; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <ListView fx:id="historyList" VBox.vgrow="ALWAYS"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>